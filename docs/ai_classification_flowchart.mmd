flowchart TD

    %% ── Термінатор START ──────────────────────────────────
    A([ПОЧАТОК])

    %% ── Введення даних (паралелограм) ────────────────────
    A --> B[/Вхідні дані звернення:\ntitle, description, request_type/]

    %% ── Процеси збереження ───────────────────────────────
    B --> C[Зберегти тікет у БД\npriority = 'medium']
    C --> D[[Запустити фоновий процес\n_run_ai_analysis]]

    %% ══════════════════════════════════════════════════════
    %% СТУПІНЬ 1 — Claude Haiku API
    %% ══════════════════════════════════════════════════════
    D --> E{ANTHROPIC_API_KEY\nзадано?}

    E -->|Так| F[Сформувати повідомлення:\nТема: title\nТип запиту: request_type\nОпис: description]
    F --> G[[Запит до Claude Haiku API\nclaude-haiku-4-5-20251001\nmax_tokens: 512]]
    G --> H{Відповідь\nотримано?}

    H -->|Так| I{JSON\nвалідний?}
    I -->|Так| J[/Результат ступеня 1:\ncategory, priority,\nsummary, recommendation/]

    I -->|Ні - виняток| FB
    H -->|Ні - помилка / таймаут| FB
    E -->|Ні| FB

    %% ══════════════════════════════════════════════════════
    %% СТУПІНЬ 2 — Keyword Fallback
    %% ══════════════════════════════════════════════════════
    FB[Об'єднати title + description\nу нижній регістр]

    FB --> K1{Ключові слова\nоплати / підписки?\nоплат, підписк, stripe,\nплатіж, рефанд, гроші}
    K1 -->|Так| R1[/category = Оплата / підписка\npriority = high/]
    K1 -->|Ні|  K2{Ключові слова\nавторизації / доступу?\nувійти, пароль, логін,\nакаунт, доступ, авториз}
    K2 -->|Так| R2[/category = Технічна проблема\npriority = high/]
    K2 -->|Ні|  K3{Ключові слова\nпомилок / збоїв?\nпомилк, баг, 500, 404,\nне працює, збій, crash}
    K3 -->|Так| R3[/category = Технічна проблема\npriority = medium/]
    K3 -->|Ні|  K4{Ключові слова\nскарги?\nскарг, незадоволен,\nпогано, жахливо, обурен}
    K4 -->|Так| R4[/category = Скарга\npriority = medium/]
    K4 -->|Ні|  K5{Ключові слова\nконсультації?\nяк, поясн, допоможіть,\nпідкаж, консульт}
    K5 -->|Так| R5[/category = Консультація\npriority = low/]
    K5 -->|Ні|  R6[/category = Інше\npriority = medium\nПотребує ручного розгляду/]

    %% ── Злиття результатів двох ступенів ─────────────────
    J  --> DB
    R1 --> DB
    R2 --> DB
    R3 --> DB
    R4 --> DB
    R5 --> DB
    R6 --> DB

    %% ── Збереження до БД (циліндр) ───────────────────────
    DB[(Записати до БД:\nai_category\nai_priority\nai_summary\nai_recommendation\nai_analyzed = True)]

    %% ── Оновлення пріоритету тікета ──────────────────────
    DB --> P{Поточний priority\nтікета = 'medium'?}
    P -->|Так| Q[priority = ai_priority]
    P -->|Ні|  R[Залишити priority\nбез змін]

    Q --> Z([КІНЕЦЬ])
    R --> Z
