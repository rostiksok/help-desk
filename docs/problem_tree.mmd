graph TD

    %% ── Наслідки (верхній ярус) ──────────────────────────
    E1[Затримки у вирішенні\nзвернень користувачів]
    E2[Незадоволеність\nкористувачів якістю підтримки]
    E3[Перевантаження одних операторів\nпри простої інших]
    E4[Неможливість аналізу\nтипових проблем та трендів]

    %% ── Центральна проблема ──────────────────────────────
    P([Відсутність ефективної системи\nуправління зверненнями\nслужби технічної підтримки])

    %% ── Причини (нижній ярус) ────────────────────────────
    C1[Ручна реєстрація та\nкатегоризація звернень]
    C2[Відсутність автоматичної\nкласифікації та пріоритизації]
    C3[Нерівномірний розподіл звернень\nміж операторами]
    C4[Відсутність аналітичних\nінструментів та звітності]
    C5[Відсутність прозорості статусу\nзвернення для користувача]

    %% ── Зв'язки: причини → проблема ─────────────────────
    C1 --> P
    C2 --> P
    C3 --> P
    C4 --> P
    C5 --> P

    %% ── Зв'язки: проблема → наслідки ────────────────────
    P --> E1
    P --> E2
    P --> E3
    P --> E4

    %% ── Стилі ────────────────────────────────────────────
    style P fill:#FF6B6B,color:#fff,stroke:#c0392b,stroke-width:2px
    style E1 fill:#FFB347,stroke:#e67e22,color:#333
    style E2 fill:#FFB347,stroke:#e67e22,color:#333
    style E3 fill:#FFB347,stroke:#e67e22,color:#333
    style E4 fill:#FFB347,stroke:#e67e22,color:#333
    style C1 fill:#AED6F1,stroke:#2980b9,color:#333
    style C2 fill:#AED6F1,stroke:#2980b9,color:#333
    style C3 fill:#AED6F1,stroke:#2980b9,color:#333
    style C4 fill:#AED6F1,stroke:#2980b9,color:#333
    style C5 fill:#AED6F1,stroke:#2980b9,color:#333
